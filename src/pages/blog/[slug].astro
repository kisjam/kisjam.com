---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { render } from "astro:content";
import { getSortedPosts, postUri } from "../../utils/posts";
import { formatDate, isSameDay } from '../../utils/date.ts';

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	return posts.map((post, i) => ({
		params: { slug: post.data.slug },
		props: {
			post,
			newer: i > 0 ? posts[i - 1] : null,
			older: i < posts.length - 1 ? posts[i + 1] : null,
		},
	}));
}

const { post, newer, older } = Astro.props;
const { title, emoji, date, categories, tags, excerpt } = post.data;
const modified = post.data.modified ?? date;
const { Content } = await render(post);

const canonical = new URL(postUri(post), Astro.site).href;
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	datePublished: date.toISOString(),
	dateModified: modified.toISOString(),
	author: { "@type": "Person", name: "Akihiro Takaoka" },
	publisher: { "@type": "Person", name: "Akihiro Takaoka" },
	mainEntityOfPage: canonical,
	url: canonical,
	...(excerpt ? { description: excerpt } : {}),
};
---
<BlogLayout title={title + ' | kisjam.com'} description={excerpt || undefined}>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	<div class="container-block">
	<article class="block-single" data-pagefind-body>
		<figure class="block-single__emoji">{ emoji }</figure>
		<div class="block-single__body">
			<div class="block-single__title">
				<h1 class="title-h1">{ title }</h1>
			</div>
			<div class="block-single__date">
				<dl class="article-date">
					<dt class="article-date__published">公開日</dt>
					<dd class="article-date__date">{ formatDate(date) }</dd>
					{
						!isSameDay(date, modified) &&
						(
							<dt class="article-date__updated">最終更新日</dt>
							<dd class="article-date__date">{ formatDate(modified) }</dd>
						)
					}
				</dl>
			</div>

			{categories.length > 0 && (
				<div class="block-single__category">
					<ul class="article-category">
						{ categories.map( (category) => (
							<li class="article-category__item"><a href={`/blog/category/${category.slug}/`}>{ category.name }</a></li>
						))}
					</ul>
				</div>
			)}

			{tags.length > 0 && (
				<div class="block-single__tag">
					<ul class="article-tag">
						{ tags.map( (tag) => (
							<li class="article-tag__item"><a href={`/blog/tag/${tag.slug}/`}>{ tag.name }</a></li>
						))}
					</ul>
				</div>
			)}
			<div class="block-single__content">
				<div class="article-content"><Content /></div>
			</div>
		</div>
	</article>
	<div class="block-pagination">
		{older ? <p class="block-pagination__prev"><a href={postUri(older)} class="block-pagination__link">← { older.data.title }</a></p> : null}
		{newer ? <p class="block-pagination__next"><a href={postUri(newer)} class="block-pagination__link">{ newer.data.title } →</a></p> : null}
	</div>
	<div class="block-pagination">
		<p class="block-pagination__next"><a href="/blog/" class="block-pagination__link">ブログ記事一覧に戻る</a></p>
	</div>
	</div>
</BlogLayout>
